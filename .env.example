# --- Supabase ---
# Project URL and anon key (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (Project Settings -> API). SERVER ONLY. Never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) ---
# https://resend.com -> API Keys
RESEND_API_KEY=
# Verified sender, e.g. "LimbList <intake@yourdomain.com>"
RESEND_FROM="LimbList <onboarding@resend.dev>"

# --- App ---
# Public base URL, used for dashboard links in emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Billing (Stripe) ---
# Billing stays OFF until BOTH STRIPE_SECRET_KEY and STRIPE_PRICE_ID are set.
# While off, the dashboard never paywalls — the app behaves as it did before.
# https://dashboard.stripe.com/apikeys (use a restricted or secret key)
STRIPE_SECRET_KEY=
# The recurring Price id for the $99/mo plan (Products -> your product -> Pricing)
STRIPE_PRICE_ID=
# Webhook signing secret (Developers -> Webhooks -> your endpoint -> Signing secret)
STRIPE_WEBHOOK_SECRET=
